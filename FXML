<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.veterinaria.VeterinariaController"
            prefHeight="600" prefWidth="900"
            stylesheets="@estilos.css">

    <children>

        <Label layoutX="250" layoutY="20"
               text="Registro de Paciente Veterinario"
               styleClass="titulo"/>

        <Label layoutX="100" layoutY="100" text="Nombre de la mascota"/>
        <TextField fx:id="txtMascota"
                   layoutX="100" layoutY="130"
                   prefWidth="250"/>

        <Label layoutX="450" layoutY="100" text="Tipo de mascota"/>
        <TextField fx:id="txtTipo"
                   layoutX="450" layoutY="130"
                   prefWidth="250"/>

        <Label layoutX="100" layoutY="190" text="Raza"/>
        <TextField fx:id="txtRaza"
                   layoutX="100" layoutY="220"
                   prefWidth="250"/>

        <Label layoutX="450" layoutY="190" text="Edad"/>
        <TextField fx:id="txtEdad"
                   layoutX="450" layoutY="220"
                   prefWidth="250"/>

        <Label layoutX="100" layoutY="280" text="Nombre del dueño"/>
        <TextField fx:id="txtDueno"
                   layoutX="100" layoutY="310"
                   prefWidth="250"/>

        <Label layoutX="450" layoutY="280" text="Motivo de la visita"/>
        <TextField fx:id="txtMotivo"
                   layoutX="450" layoutY="310"
                   prefWidth="250"/>

        <Button text="Registrar"
                layoutX="300" layoutY="420"
                onAction="#registrar"
                styleClass="btnRegistrar"/>

        <Button text="Limpiar"
                layoutX="500" layoutY="420"
                onAction="#limpiar"
                styleClass="btnLimpiar"/>

    </children>
</AnchorPane>